{
  "name": "@tokenscope/proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@tokenscope/shared": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.5.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.0",
    "wrangler": "^4.77.0"
  }
}
