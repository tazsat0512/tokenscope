{
  "name": "reivo",
  "version": "0.1.0",
  "private": true,
  "description": "AI agent token consumption visibility and auto-stop proxy",
  "scripts": {
    "dev:proxy": "turbo run dev --filter=@reivo/proxy",
    "dev:dashboard": "turbo run dev --filter=@reivo/dashboard",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@reivo/proxy",
    "db:migrate": "turbo run db:migrate --filter=@reivo/proxy"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9"
  }
}
